# Server
DB_HOST=localhost
DB_PORT=3306
DB_NAME=workout_app
DB_USER=root
DB_PASSWORD=yourpassword

# SSL — set to true for cloud databases (RDS, PlanetScale, Railway, Supabase, etc.)
DB_SSL=false
# Set to false only if your provider uses a self-signed cert
DB_SSL_REJECT_UNAUTHORIZED=true

# API server
SERVER_PORT=3001

# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:5173
